# Review reply and post controls.
ISLAND_BOY_BUSINESS_NAME=Island Boy Kreationz Food Truck & Catering
ISLAND_BOY_REVIEW_REPLY_LIMIT=5
ISLAND_BOY_REVIEW_REPLY_DRY_RUN=0
